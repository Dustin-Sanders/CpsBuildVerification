{
  "GlobalRules": [
    {
      "RuleName": "Auto-Approve Messaging Edits",
      "Description": "Allows endpoints and routing to drift in messaging configs without failing the build.",
      "FileMatch": "*Messaging.xml",
      "AllowedChangeTypes": [
        "*"
      ],
      "Action": "Informational"
    },
    {
      "RuleName": "Auto-Approve Expected Binary Edits",
      "Description": "Allows recompilation and new binary dependencies. Deleted binaries will still fail the build.",
      "FileMatch": "*.dll|*.pdb|*.exe|*.jar",
      "AllowedChangeTypes": [
        "BinaryChecksumMismatch",
        "FileMissingInDifference"
      ],
      "Action": "Informational"
    },
    {
      "RuleName": "Auto-Approve Assembly Config Edits",
      "Description": "Allows all changes to auto-generated assembly and dependency configs.",
      "FileMatch": "*.dll.config|*.deps.json",
      "AllowedChangeTypes": [
        "*"
      ],
      "Action": "Informational"
    },
    {
      "RuleName": "Auto-Approve XML Edits",
      "Description": "Allows deletion and modification of XML elements/attributes. Fails the build if new elements/attributes are added.",
      "FileMatch": "*.config|*.xml",
      "AllowedChangeTypes": [
        "FileAddedInDifference",
        "NodeAddedInDifference",
        "AttributeAddedInDifference",
        "LineAddedInDifference",
        "NodeModifiedInDifference",
        "AttributeValueChanged",
        "InnerTextChanged",
        "LineModified"
      ],
      "Action": "Informational"
    },
    {
      "RuleName": "Auto-Approve JSON Edits",
      "Description": "Allows deletion and modification of JSON properties. Fails the build if new properties are added.",
      "FileMatch": "*.json",
      "AllowedChangeTypes": [
        "FileAddedInDifference",
        "AddedInDifference",
        "ValueChanged",
        "TypeOrNullMismatch"
      ],
      "Action": "Informational"
    },
    {
      "RuleName": "Auto-Approve UI Asset Edits",
      "Description": "Allows modifications to UI assets.",
      "FileMatch": "*.aspx|*.js|*.html",
      "AllowedChangeTypes": [
        "LineModified",
        "LineAddedInDifference",
        "LineMissingInDifference",
        "FileMissingInDifference",
        "FileAddedInDifference"
      ],
      "Action": "Informational"
    },
    {
      "RuleName": "Auto-Approve FSC PowerShell Scripts",
      "Description": "Ignores cascading line differences in script files for FSC Letters and Statements.",
      "FileMatch": "*.ps1|*.psd1",
      "PathMatch": "*FSC_Letters*|*FSC_Statements*|*ETL_FSCLTRS*|*ETL_FSCSTMNT*",
      "AllowedChangeTypes": [
        "*"
      ],
      "Action": "Hide"
    },
	{
      "RuleName": "Auto-Approve CPS SG UI > ng > assets",
      "Description": "Ignores cascading line differences in script files for FSC Letters and Statements.",
      "FileMatch": "*.png|*.ico|*.gif|*.css|*.sqlite|*.eot|*.ttf|*.svg|*.woff|*.webp|*.ali|*.map",
      "PathMatch": "*CPSServicesGateway*|*SOA_CPSSG*",
      "AllowedChangeTypes": [
        "FileMissingInDifference",
		"BinaryChecksumMismatch",
		"FileAddedInDifference"
      ],
      "Action": "Informational"
    }    
  ]
}