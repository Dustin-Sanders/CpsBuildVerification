{
  "GlobalRules": [
    {
      "RuleName": "Auto-Approve Messaging Configuration Drift",
      "Description": "Allows endpoints and routing to drift in messaging configs without failing the build. Shown in report.",
      "FileMatch": "*Messaging.xml",
      "AllowedChangeTypes": [
        "*"
      ],
      "Action": "Informational"
    },
    {
      "RuleName": "Auto-Approve Expected Binary Churn",
      "Description": "Allows recompilation and new binary dependencies. Deleted binaries will still fail the build. Shown in report.",
      "FileMatch": "*.dll|*.pdb|*.exe",
      "AllowedChangeTypes": [
        "BinaryChecksumMismatch",
        "FileMissingInDifference",
        "MissingInDifference"
      ],
      "Action": "Informational"
    },
    {
      "RuleName": "Auto-Approve Assembly Config Generation",
      "Description": "Accepts all changes to auto-generated assembly configs. Shown in report.",
      "FileMatch": "*.dll.config",
      "AllowedChangeTypes": [
        "*"
      ],
      "Action": "Informational"
    },
    {
      "RuleName": "Auto-Approve XML and Config Deletions",
      "Description": "Allows deletion and modification of XML elements/attributes. Fails the build if new elements/attributes are added.",
      "FileMatch": "*.config|*.xml",
      "AllowedChangeTypes": [
        "FileAddedInDifference",
        "NodeAddedInDifference",
        "AttributeAddedInDifference",
        "LineAddedInDifference",
        "NodeModifiedInDifference",
        "AttributeValueChanged",
        "InnerTextChanged",
        "LineModified"
								  
      ],
      "Action": "Informational"
    },
    {
      "RuleName": "Auto-Approve JSON Deletions",
      "Description": "Allows deletion and modification of JSON properties. Fails the build if new properties are added.",
      "FileMatch": "*.json",
      "AllowedChangeTypes": [
        "FileAddedInDifference",
        "AddedInDifference",
        "ValueChanged",
        "TypeOrNullMismatch"
      ],
      "Action": "Informational"
    },
    {
      "RuleName": "Auto-Approve ASPX UI Changes",
      "Description": "Allows modifications to ASPX pages. Shown in report.",
      "FileMatch": "*.aspx",
      "AllowedChangeTypes": [
        "LineModified",
        "LineAddedInDifference",
        "LineMissingInDifference"
      ],
      "Action": "Informational"
    }
  ]
}